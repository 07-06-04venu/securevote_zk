# ─── Gemini AI (required for ID & biometric verification) ───────────────────
# Get your key at: https://aistudio.google.com/app/apikey
# Replace the value below with your actual key — do NOT leave it as the placeholder.
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: override the Gemini model (default: gemini-2.0-flash)
# GEMINI_MODEL=gemini-2.0-flash

# ─── MongoDB ─────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<db_user>:<db_password>@<cluster-host>/securevote?retryWrites=true&w=majority
MONGODB_URI_NONSRV=mongodb://<db_user>:<db_password>@<shard0>,<shard1>,<shard2>/securevote?tls=true&authSource=admin&replicaSet=<atlas-replica-set>&retryWrites=true&w=majority
MONGODB_DB_NAME=securevote

# ─── Blockchain ──────────────────────────────────────────────────────────────
RPC_URL=http://127.0.0.1:8545
CONTRACT_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3
VOTE_RELAYER_PRIVATE_KEY=replace_with_relayer_private_key

# ─── Feature flags ───────────────────────────────────────────────────────────
VITE_ALLOW_INSECURE_DEMO_VERIFICATION=false

# ─── Google Vision (optional, legacy) ────────────────────────────────────────
GOOGLE_VISION_API_KEY=your_google_vision_api_key_here

# ─── ID verification service port ────────────────────────────────────────────
ID_VERIFY_PORT=8081
